export default function ProfileScreen() {
  const SkillTag = ({ skill }) => (
    <View style={styles.skillTag}>
      <Text style={styles.skillTagText}>{skill}</Text>
    </View>
  );

  return (
    <SafeAreaView style={styles.container}>
      <ScrollView
